<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean id="bookRepository" class="com.library.repository.BookRepository" />

    <bean id="bookService" class="com.library.service.BookService">
        <!-- constructor injection - the library name goes in through the constructor -->
        <constructor-arg value="city central library" />
        <!-- setter injection - spring calls setRepository with the bean below -->
        <property name="repository" ref="bookRepository" />
    </bean>

</beans>
